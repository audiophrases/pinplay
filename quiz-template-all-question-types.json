    "templateGuide":  {
                          "purpose":  "Reference template covering all PinPlay question types with practical examples and feature usage notes.",
                          "defaultStyle":  "No time limit by default. Confidence-building flow: teach/scaffold first, then varied practice.",
                          "questionTypes":  {
                                                "mcq":  "Single correct option.",
                                                "multi":  "Select all correct options.",
                                                "tf":  "True/False variant of MCQ.",
                                                "text":  "Auto-check short typed answers against accepted list.",
                                                "open":  "Teacher-graded free response.",
                                                "context_gap":  "Fill ordered blanks from context.",
                                                "match_pairs":  "Match left and right items.",
                                                "error_hunt":  "Find/fix sentence error; compare with corrected target.",
                                                "puzzle":  "Reorder items into correct sequence.",
                                                "slider":  "Numeric estimate with margin tolerance.",
                                                "pin":  "Pinpoint location(s) on image; supports one or multiple zones with pinMode any/all.",
                                                "audio":  "Audio-first question (TTS or uploaded file) with answers."
                                            },
                          "featureGuides":  {
                                                "poll":  {
                                                             "how":  "Set isPoll=true on a question to collect responses anonymously with no points.",
                                                             "behavior":  "Works with most question types; useful for warm-up checks or opinion prompts."
                                                         },
                                                "audio":  {
                                                              "fields":  "audioEnabled, audioMode(tts|file), audioText, language, audioData",
                                                              "note":  "Only mention/use audio when enabled or provided."
                                                          },
                                                "image":  {
                                                              "fields":  "imageData used by shared-image questions and required by pin/image_open.",
                                                              "note":  "Use clear pedagogical visuals; keep prompt readable near image."
                                                          },
                                                "pin":  {
                                                            "fields":  "zones[], zone (legacy), pinMode(any|all)",
                                                            "note":  "pinMode=all requires covering all correct zones; pinMode=any accepts one correct zone."
                                                        }
                                            }
