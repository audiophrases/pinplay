  "templateGuide": {
    "purpose": "Master reference template for teachers and AI agents to understand every PinPlay quiz feature, field, workflow, and classroom use-case.",
    "defaultStyle": "Default classroom mode uses no time limit (timeLimit=0) and a confidence-building sequence (teach/scaffold first, then varied practice).",
    "coverage": [
      "All currently supported question types (mcq, multi, tf, text, open, context_gap, match_pairs, error_hunt, puzzle, slider, pin, audio).",
      "Teacher-graded workflows (open/image_open and text with empty accepted list).",
      "Live-game behaviors: polls, reactions, timer/no-timer, grading, corrections, model answers, answer history, and projector display.",
      "Media workflows: upload, clipboard paste, search web image, clear image, audio (tts/file)."
    ],
    "canonicalFieldRules": {
      "commonRequired": [
        "id",
        "type",
        "prompt",
        "points",
        "timeLimit"
      ],
      "commonOptional": [
        "isPoll",
        "audioEnabled",
        "audioMode",
        "audioText",
        "language",
        "audioData",
        "imageData"
      ],
      "points": "Recommended values in builder are 0/1000/2000, but numeric values are accepted. In live score logic, points are clamped and normalized per type.",
      "timeLimit": "0 = no timer. For timed questions use positive seconds. Keep accessibility in mind for EAL/ELL learners.",
      "ids": "Use stable unique ids per question (slug-like). This helps safe rewrites/versioning by AI tools."
    },
    "questionTypes": {
      "mcq": {
        "summary": "Single-choice auto-graded.",
        "required": [
          "answers[] with exactly one correct=true"
        ],
        "tips": [
          "Best for vocabulary, grammar choice, quick checks.",
          "Keep distractors plausible but clearly wrong."
        ]
      },
      "multi": {
        "summary": "Multiple-choice, select all correct.",
        "required": [
          "answers[] with two or more correct options when possible"
        ],
        "tips": [
          "Use clear instructions (e.g., ?Select all that apply?).",
          "Avoid trick negatives unless explicitly taught."
        ]
      },
      "tf": {
        "summary": "True/False variant, still represented as answers[].",
        "required": [
          "answers with True/False text and one marked correct"
        ],
        "tips": [
          "Use for concept checks; avoid ambiguous wording."
        ]
      },
      "text": {
        "summary": "Typed answer; can be auto-graded or teacher-graded depending on accepted[] content.",
        "required": [
          "accepted[] for auto-grade mode (normalized matching)"
        ],
        "teacherGradedMode": "If accepted[] is empty/blank, text behaves as teacher-graded open response in live mode.",
        "tips": [
          "Add common variants/synonyms in accepted[].",
          "Keep expected spelling policy explicit."
        ]
      },
      "open": {
        "summary": "Teacher-graded free response.",
        "required": [
          "Prompt optimized for 1?2 concise sentences"
        ],
        "teacherTools": [
          "Grade/Regrade points",
          "Correction feedback to student",
          "Mark/unmark as model answer",
          "Hide response from displays"
        ]
      },
      "context_gap": {
        "summary": "Fill-in-the-blank from context.",
        "required": [
          "gaps[] ordered to match blanks in prompt (____ or [])"
        ],
        "tips": [
          "Keep gap count low on first pass (1?3).",
          "Use meaningful sentence context, not isolated words."
        ]
      },
      "match_pairs": {
        "summary": "Match left-right associations.",
        "required": [
          "pairs[] of {left,right}"
        ],
        "tips": [
          "Use parallel structure and balanced difficulty."
        ]
      },
      "error_hunt": {
        "summary": "Identify wrong tokens and rewrite correctly.",
        "required": [
          "corrected",
          "requiredErrors"
        ],
        "tips": [
          "Great for grammar diagnosis and metalinguistic discussion."
        ]
      },
      "puzzle": {
        "summary": "Reorder shuffled tokens/items.",
        "required": [
          "items[] in correct final order"
        ],
        "tips": [
          "Keep item count 4?9 for speed and mobile readability."
        ]
      },
      "slider": {
        "summary": "Numeric estimate with tolerance margin.",
        "required": [
          "min",
          "max",
          "target",
          "margin"
        ],
        "validMargins": [
          "none",
          "low",
          "medium",
          "high",
          "maximum"
        ],
        "tips": [
          "Use realistic ranges and optionally unit."
        ]
      },
      "pin": {
        "summary": "Locate point(s) on an image.",
        "required": [
          "imageData",
          "zones[] (or zone legacy)",
          "pinMode"
        ],
        "pinMode": "all = every target zone must be covered; any = one correct zone is enough.",
        "tips": [
          "Prefer clear images with visible landmarks.",
          "Use multiple zones only when pedagogically justified."
        ]
      },
      "audio": {
        "summary": "Audio-first prompt with selectable answers.",
        "required": [
          "audioEnabled=true plus either audioText(TTS) or audioData(file)"
        ],
        "tips": [
          "Keep clip short and clean for classroom acoustics."
        ]
      }
    },
    "featureGuides": {
      "poll": {
        "how": "Set isPoll=true to collect anonymous responses with 0 points.",
        "behavior": [
          "No correct-answer reveal or scoring.",
          "Useful for warm-ups, opinion checks, confidence surveys."
        ]
      },
      "audio": {
        "fields": [
          "audioEnabled",
          "audioMode(tts|file)",
          "audioText",
          "language",
          "audioData"
        ],
        "liveBehavior": [
          "Host/live can autoplay at question start when enabled.",
          "Students use manual play button."
        ]
      },
      "images": {
        "fields": [
          "imageData for standard question visuals",
          "pin zones for pin questions"
        ],
        "builderWorkflows": [
          "File upload",
          "Clipboard paste (Ctrl+V)",
          "Web image search grid",
          "Clear image button"
        ],
        "advice": "Use high-contrast images and concise prompts for mobile readability."
      },
      "teacherGrading": {
        "where": "Teacher-only Answer history panel (private controls).",
        "tools": [
          "Grade/Regrade points",
          "Write correction feedback",
          "Choose model answers for live screen",
          "Hide inappropriate/low-quality responses"
        ],
        "studentFeedback": "After grading/reveal, students can see correction text and awarded points."
      },
      "modelAnswers": {
        "purpose": "Show selected student responses as exemplars on live screen.",
        "note": "Teacher explicitly controls which responses are visible as models."
      },
      "reactions": {
        "summary": "Students can send quick emoji reactions; host screen displays reaction pops.",
        "note": "Emoji allowlist is controlled in client+worker constants and must stay synced."
      }
    },
    "authoringPatterns": {
      "teachVsPractice": {
        "teach": "Start with scaffolded examples, lower cognitive load, explicit clues.",
        "practice": "Reduce scaffolds, increase retrieval and transfer, mix formats."
      },
      "progression": "Recommended sequence: mcq/tf -> multi/text -> context/puzzle/match -> open/pin/slider -> reflective open.",
      "differentiation": [
        "Duplicate core item with easier/harder distractors.",
        "Use optional audio/image support for weaker readers."
      ]
    },
    "aiAuthorChecklist": [
      "Keep prompts classroom-safe and age-appropriate.",
      "Ensure each question has the fields required by its type.",
      "Avoid unsupported/legacy question types (image_open is removed from authoring templates).",
      "Prefer timeLimit=0 unless timing is intentionally part of pedagogy.",
      "For teacher-graded tasks, provide clear scoring criteria in the prompt.",
      "Verify slider margin is one of: none/low/medium/high/maximum."
    ],
    "versioningNotes": {
      "templateVersion": 3,
      "compatibility": "Designed for current PinPlay builder/live flow. Keep alias file (pinplay-template.json) synced with quiz-template-all-question-types.json.",
      "maintenance": "When features change, update this templateGuide first so teachers and AI tools stay aligned."
    }
  }
}
