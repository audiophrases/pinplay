{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pinplay",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "exclude": [
      ".git",
      ".wrangler",
      "node_modules",
      "cloudflare",
      "tests",
      "*.cmd",
      "*.log"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
