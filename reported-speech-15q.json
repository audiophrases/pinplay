{
  "version": 1,
  "title": "Reported Speech Challenge (15 Questions)",
  "questions": [
    {
      "id": "q1",
      "type": "mcq",
      "prompt": "Direct: \"I am tired,\" she said. Choose the best reported sentence.",
      "points": 1000,
      "timeLimit": 20,
      "answers": [
        { "text": "She said that she was tired.", "correct": true },
        { "text": "She said that she is tired.", "correct": false },
        { "text": "She said she tired.", "correct": false },
        { "text": "She says that she was tired.", "correct": false }
      ]
    },
    {
      "id": "q2",
      "type": "mcq",
      "prompt": "Choose the correct reporting verb pattern: \"Please, open the window,\" she said to me.",
      "points": 1000,
      "timeLimit": 20,
      "audioEnabled": true,
      "audioMode": "tts",
      "audioText": "Please, open the window, she said to me.",
      "language": "en-US",
      "answers": [
        { "text": "She asked me to open the window.", "correct": true },
        { "text": "She asked me open the window.", "correct": false },
        { "text": "She said me to open the window.", "correct": false },
        { "text": "She told me that open the window.", "correct": false }
      ]
    },
    {
      "id": "q3",
      "type": "multi",
      "prompt": "Select all changes that are usually needed in reported speech.",
      "points": 1000,
      "timeLimit": 25,
      "answers": [
        { "text": "Backshift of tense (present -> past)", "correct": true },
        { "text": "Pronoun changes", "correct": true },
        { "text": "Time/place expression changes", "correct": true },
        { "text": "Always keep quotation marks", "correct": false },
        { "text": "Always use present simple", "correct": false }
      ]
    },
    {
      "id": "q4",
      "type": "tf",
      "prompt": "In reported speech, \"will\" often changes to \"would\".",
      "points": 1000,
      "timeLimit": 12,
      "answers": [
        { "text": "True", "correct": true },
        { "text": "False", "correct": false }
      ]
    },
    {
      "id": "q5",
      "type": "tf",
      "prompt": "\"Yesterday\" usually stays \"yesterday\" in reported speech.",
      "points": 1000,
      "timeLimit": 12,
      "audioEnabled": true,
      "audioMode": "tts",
      "audioText": "Yesterday usually stays yesterday in reported speech.",
      "language": "en-US",
      "answers": [
        { "text": "True", "correct": false },
        { "text": "False", "correct": true }
      ]
    },
    {
      "id": "q6",
      "type": "text",
      "prompt": "Rewrite one word: Direct \"today\" -> Reported ?",
      "points": 1000,
      "timeLimit": 20,
      "accepted": ["that day", "the same day", "on that day", "that very day"]
    },
    {
      "id": "q7",
      "type": "text",
      "prompt": "Rewrite one word: Direct \"now\" -> Reported ?",
      "points": 1000,
      "timeLimit": 20,
      "audioEnabled": true,
      "audioMode": "tts",
      "audioText": "Rewrite one word: direct now to reported speech.",
      "language": "en-US",
      "accepted": ["then", "at that moment", "at that time", "just then"]
    },
    {
      "id": "q8",
      "type": "open",
      "prompt": "Open answer: Convert this sentence to reported speech: \"I have finished my homework,\" Alex said.",
      "points": 1000,
      "timeLimit": 45
    },
    {
      "id": "q9",
      "type": "open",
      "prompt": "Open answer: Report this question: \"Where do you live?\" she asked me.",
      "points": 1000,
      "timeLimit": 45,
      "audioEnabled": true,
      "audioMode": "tts",
      "audioText": "Where do you live? she asked me.",
      "language": "en-US"
    },
    {
      "id": "q10",
      "type": "puzzle",
      "prompt": "Put the words in order for correct reported speech.",
      "points": 1000,
      "timeLimit": 35,
      "items": [
        "She",
        "said",
        "that",
        "she",
        "was",
        "busy"
      ]
    },
    {
      "id": "q11",
      "type": "puzzle",
      "prompt": "Order this reported question.",
      "points": 1000,
      "timeLimit": 35,
      "audioEnabled": true,
      "audioMode": "tts",
      "audioText": "He asked me where I had been.",
      "language": "en-US",
      "items": [
        "He",
        "asked",
        "me",
        "where",
        "I",
        "had",
        "been"
      ]
    },
    {
      "id": "q12",
      "type": "mcq",
      "prompt": "Direct: \"Don't be late,\" Dad said. Best report?",
      "points": 1000,
      "timeLimit": 20,
      "answers": [
        { "text": "Dad told me not to be late.", "correct": true },
        { "text": "Dad said me don't be late.", "correct": false },
        { "text": "Dad asked me don't to be late.", "correct": false },
        { "text": "Dad told that I not be late.", "correct": false }
      ]
    },
    {
      "id": "q13",
      "type": "slider",
      "prompt": "Confidence check: How sure are you about reported speech rules?",
      "points": 1000,
      "timeLimit": 15,
      "min": 0,
      "max": 100,
      "target": 80,
      "margin": "maximum",
      "unit": "%"
    },
    {
      "id": "q14",
      "type": "multi",
      "prompt": "Select all direct->reported time changes that are correct.",
      "points": 1000,
      "timeLimit": 25,
      "answers": [
        { "text": "tomorrow -> the next day", "correct": true },
        { "text": "yesterday -> the day before", "correct": true },
        { "text": "next week -> the following week", "correct": true },
        { "text": "here -> now", "correct": false },
        { "text": "this -> these (always)", "correct": false }
      ]
    },
    {
      "id": "q15",
      "type": "open",
      "prompt": "Final challenge (open): Report this command politely: \"Could you close the door, please?\"",
